# ============================
# Watt Security — .gitignore
# ============================

# ---- Windows ----
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# ---- VS Code ----
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# ---- Node / npm ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/
.pnp.*

# ---- Build / Output ----
dist/
build/
out/
.cache/
.parcel-cache/

# ---- Environment / Secrets ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- Logs ----
logs/
*.log

# ---- Temporary files ----
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*
.DS_Store

# ---- OS-generated (macOS, kept for cross-platform collaborators) ----
.AppleDouble
.LSOverride

# ---- Editor / IDE (misc) ----
.idea/
*.sublime-workspace
*.sublime-project
